import numpy as np
import matplotlib.pyplot as plt
import sys
import os
from pathlib import Path

# --------------------------------------------------
# IMPORTS (adjust if needed)
# --------------------------------------------------
sys.path.append(str(Path.cwd()))
from modules import NNCompute
from modules import configLoader
from modules import validateInputs
from modules.NNGeometryN import Layer





# --------------------------------------------------
# 1. Load config
# --------------------------------------------------

import os
    
    # load the config file
from pathlib import Path
BASE_DIR = Path.cwd()

configFile = BASE_DIR / "configParseBody.ini"
config = configLoader.load_config(configFile)



validateInputs.validateInputs(config)



print("Config loaded.")
print("Cavity type:", config.cavityType)





# --------------------------------------------------
# 2. DEFINE BASE LAYER
# --------------------------------------------------
layer = Layer(
    xMin=-config.xExtent / 2,
    xMax= config.xExtent / 2,
    yMin=-config.yExtent / 2,
    yMax= config.yExtent / 2,
    zTop=0,
    zBot=config.zExtent,
    vP=3000,
    vS=1500,
    rho=2000
)

# Frequencies
nFreq = 5
freqOut = np.linspace(1, 10, nFreq)



# Cavity dimensions
if config.cavityType == "cuboid":
    ax = config.cavityLength / 2
    ay = config.cavityWidth  / 2
    az = config.cavityHeight / 2
else:
    ax = ay = az = config.cavityRadius


# --------------------------------------------------
# 3. TEST MULTIPLE CAVITY DEPTHS
# --------------------------------------------------
depths = [0, 100, 200, 350]

results_all = []

for zC in depths:

    print(f"\n=== Running cavity at depth {zC} ===")

    # classify intersection
    layer.intersectionType = layer.classifyIntersection(zC - az, zC + az)
    print("Intersection type:", layer.intersectionType)

    # generate blocks
    layer.generateBlocks(
        xMin=-config.xExtent/2,
        xMax= config.xExtent/2,
        yMin=-config.yExtent/2,
        yMax= config.yExtent/2,
        zC=zC,
        ax=ax, ay=ay, az=az,
        domXYBounds=(
            -config.xExtent/2,
             config.xExtent/2,
            -config.yExtent/2,
             config.yExtent/2
        )
    )

    print(f"Generated {len(layer.blocks)} blocks")

    # --------------------------------------------------
    # PLOT GEOMETRY (ONLY FIRST DEPTH)
    # --------------------------------------------------
    if zC == depths[0]:

        # --- XY view ---
        plt.figure()
        for block in layer.blocks:
            x = [block.xMin, block.xMax, block.xMax, block.xMin, block.xMin]
            y = [block.yMin, block.yMin, block.yMax, block.yMax, block.yMin]
            plt.plot(x, y)

        plt.title("Block layout (XY view)")
        plt.xlabel("X")
        plt.ylabel("Y")
        plt.axis("equal")
        plt.grid()
        plt.show()

        # --- XZ view ---
        plt.figure()
        for block in layer.blocks:
            x = [block.xMin, block.xMax, block.xMax, block.xMin, block.xMin]
            z = [block.zMin, block.zMin, block.zMax, block.zMax, block.zMin]
            plt.plot(x, z)

        # cavity
        if config.cavityType == "cuboid":
            x_cav = [-ax, ax, ax, -ax, -ax]
            z_cav = [zC-az, zC-az, zC+az, zC+az, zC-az]
            plt.plot(x_cav, z_cav)
        else:
            theta = np.linspace(0, 2*np.pi, 100)
            x_cav = config.cavityRadius * np.cos(theta)
            z_cav = zC + config.cavityRadius * np.sin(theta)
            plt.plot(x_cav, z_cav)

        plt.gca().invert_yaxis()
        plt.title("XZ cross-section")
        plt.xlabel("X")
        plt.ylabel("Depth")
        plt.grid()
        plt.show()


    # --------------------------------------------------
    # 4. RUN NN COMPUTATION
    # --------------------------------------------------
    I_total = np.zeros((nFreq, 3), dtype=np.complex128)

    for i, block in enumerate(layer.blocks):
        print(f"Running block {i+1}/{len(layer.blocks)}")

        result = NNCompute.runVolNNComputeBlock(
            block=block,
            gridSize=200,
            freqOut=freqOut,
            cubeC=zC,

            rCavity=(config.cavityLength,
                     config.cavityWidth,
                     config.cavityHeight) if config.cavityType == "cuboid"
                     else config.cavityRadius,

            cavity_length=config.cavityLength,
            cavity_width=config.cavityWidth,
            cavity_height=config.cavityHeight,
            cavity_type=config.cavityType,

            xSrc=0, ySrc=0,
            azSrc=[0],
            srcMeta={
                "phiSrc": np.array([0.0]),
                "ampSrc": np.array([1.0])
            },
            idxFreq=None,
            fMin=None, fMax=None,
            outDispPath=None,
            splitAll=None,
            xMaxGF=None,
            fInpPath=None,
            components=None,
            vR=None,
            useSimDisp=False,
            ifRay=1,
            ifBody=0,
            nCPUDisp=1,
            nCPUNN=1,
            nChunk=5000
        )

        I_total += result

    results_all.append(I_total)


# --------------------------------------------------
# 5. PLOT RESULTS
# --------------------------------------------------
plt.figure()

for i, zC in enumerate(depths):
    I = results_all[i]
    magnitude = np.linalg.norm(I, axis=1)
    plt.plot(freqOut, magnitude)

plt.xlabel("Frequency (Hz)")
plt.ylabel("|I|")
plt.title("NN response vs frequency (different cavity depths)")
plt.grid()
plt.show()


print("\nDone.")
